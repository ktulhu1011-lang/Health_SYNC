# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Garmin
GARMIN_ENCRYPTION_KEY=your_32_byte_base64_key_here  # AES-256 ключ для токенов

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=postgresql://healthsync:healthsync@db:5432/healthsync

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE_MINUTES=10080  # 7 дней

# App
FRONTEND_URL=https://yourdomain.com
GARMIN_SYNC_HOUR=3                # Час ночной синхронизации
WEEKLY_INSIGHT_DAY=sunday         # День еженедельного инсайта
OPTIONAL_MORNING_REMINDER=08:00   # Опциональное утреннее уведомление сна из Garmin

# Users (создаются при деплое)
USER1_USERNAME=user1
USER1_PASSWORD=change_me_1
USER1_TELEGRAM_ID=123456789

USER2_USERNAME=user2
USER2_PASSWORD=change_me_2
USER2_TELEGRAM_ID=987654321
